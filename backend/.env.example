# Copia este archivo como .env y reemplaza los valores.
# Formato: postgresql+asyncpg://usuario:password@host:puerto/base_de_datos
DATABASE_URL=postgresql+asyncpg://constructo_user:tu_password@localhost:5432/constructo_db
# Si pegas un DSN de Neon con sslmode/channel_binding, la app lo normaliza para asyncpg.

# Activa logs SQL solo en desarrollo (true/false)
SQLALCHEMY_ECHO=false

# Crear tablas automaticamente al arrancar (solo desarrollo)
AUTO_CREATE_TABLES=true

# Configuracion JWT para autenticacion basica
JWT_SECRET_KEY={"tu_clave_secreta_para_jwt"}
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
